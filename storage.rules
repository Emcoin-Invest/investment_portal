rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isClient() {
      return isSignedIn() && request.auth.token.role == 'client';
    }

    function isOwnFile(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ========================================================================
    // STATEMENTS FOLDER
    // ========================================================================
    match /statements/{userId}/{allPaths=**} {
      // Clients can read only their own statement files
      allow read: if isClient() && isOwnFile(userId);
      // Admins can read all statement files
      allow read: if isAdmin();
      // Only admins can upload statement files
      allow write: if isAdmin() && request.resource.size < 50 * 1024 * 1024; // 50MB limit
    }

    // ========================================================================
    // DENY ALL OTHER ACCESS
    // ========================================================================
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
